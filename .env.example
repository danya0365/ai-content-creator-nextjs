# Optional: Database URL for direct database access (ใช้สำหรับ migrations)
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI Content Creator"

# Colyseus Multiplayer Server Configuration
NEXT_PUBLIC_COLYSEUS_HOST=localhost
NEXT_PUBLIC_COLYSEUS_PORT=2567
NEXT_PUBLIC_COLYSEUS_SECURE=false
COLYSEUS_PORT=2567

# Optional: Analytics (ถ้ามีการใช้งาน)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Optional: Storage Configuration
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# NEXT_PUBLIC_CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Optional: External APIs
# YOUTUBE_API_KEY=your-youtube-api-key

# Optional: Email Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=your-email-from-email
EMAIL_FROM_NAME=your-email-from-name


# ========================================
# Auth Configuration - Login Methods
# ========================================
# Email/Password login (default: enabled)
NEXT_PUBLIC_AUTH_EMAIL_ENABLED=true

# Allow new user registration (default: enabled)
NEXT_PUBLIC_AUTH_REGISTRATION_ENABLED=false

# Phone/OTP login (default: disabled)
NEXT_PUBLIC_AUTH_PHONE_ENABLED=false

# OAuth login (default: disabled)
NEXT_PUBLIC_AUTH_OAUTH_ENABLED=false

# Individual OAuth providers (only used if OAUTH_ENABLED=true)
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=false
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=false
NEXT_PUBLIC_AUTH_LINE_ENABLED=false

# ========================================
# Auth Features
# ========================================
# Forgot password feature
NEXT_PUBLIC_AUTH_FORGOT_PASSWORD_ENABLED=true

# Email verification required
NEXT_PUBLIC_AUTH_EMAIL_VERIFICATION_ENABLED=true

# Remember me checkbox
NEXT_PUBLIC_AUTH_REMEMBER_ME_ENABLED=true

# ============================================
# AI Content Creator Configuration
# ============================================

# AI Provider Selection
# Options: gemini, groq, openrouter, wavespeed, mock
AI_PROVIDER=wavespeed

# AI Image Provider Selection
# Options: gemini, together, pollinations, dicebear, wavespeed, mock
AI_IMAGE_PROVIDER=wavespeed

# Groq API Key (FREE tier available)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Together AI API Key (FREE credits - for image generation with FLUX)
# Get your key from: https://api.together.ai/
TOGETHER_API_KEY=your-together-api-key-here

# Google Gemini API Key (Required for AI content generation)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API Key (alternative - has FREE models)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Wavespeed AI API Key
# Get your key from: https://wavespeed.ai/
WAVESPEED_API_KEY=your-wavespeed-api-key-here

# Wavespeed Content Model (LLM for text generation)
# Options: deepseek-ai/deepseek-v3, deepseek-ai/deepseek-coder,
#          meta-llama/llama-3.1-8b-instruct, meta-llama/llama-3.1-70b-instruct,
#          meta-llama/llama-3-8b-instruct, meta-llama/llama-3-70b-instruct,
#          qwen/qwen-2.5-72b-instruct
WAVESPEED_CONTENT_MODEL=deepseek-ai/deepseek-v3

# Wavespeed Image Model (text-to-image)
# Options: wavespeed-ai/flux-schnell, wavespeed-ai/flux-dev,
#          wavespeed-ai/z-image/turbo, black-forest-labs/flux-schnell,
#          google/nano-banana-2/text-to-image, google/nano-banana-pro/text-to-image,
#          bytedance/seedream-v4.5/edit
# Tip: ใช้ wavespeed-ai/flux-dev สำหรับ dev, wavespeed-ai/flux-schnell สำหรับ prod
WAVESPEED_IMAGE_MODEL=wavespeed-ai/flux-schnell

# Cron Job Secret (for protecting /api/cron/generate endpoint)
CRON_SECRET=your-secure-cron-secret-here